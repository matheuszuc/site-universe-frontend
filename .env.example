VITE_API_URL=http://localhost:3333
# reCAPTCHA v3 (score, invisivel) — site key PUBLICA (NUNCA colocar secret key aqui)
# Obtenha em: https://www.google.com/recaptcha/admin/create (tipo: reCAPTCHA v3)
# IMPORTANTE: adicionar localhost no console do reCAPTCHA para dev local funcionar
# IMPORTANTE: adicionar o dominio real no console do reCAPTCHA antes de ir para producao
# IMPORTANTE: apos alterar este arquivo, reiniciar o servidor frontend (npm run dev)
# Funcionamento: o script v3 e carregado no index.html (render=%VITE_RECAPTCHA_SITE_KEY%)
#   e executado no submit de Login/Registro. Para desativar em dev, VITE_RECAPTCHA_ENABLED=false.
VITE_RECAPTCHA_SITE_KEY=
# false = desativa o reCAPTCHA (bypass para dev sem chave). Ausente ou qualquer outro valor = ativo.
VITE_RECAPTCHA_ENABLED=false
