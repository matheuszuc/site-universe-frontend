VITE_API_URL=http://localhost:3333
# reCAPTCHA v2 ("Nao sou um robo") — site key PUBLICA (NUNCA colocar secret key aqui)
# Obtenha em: https://www.google.com/recaptcha/admin/create (tipo: reCAPTCHA v2 checkbox)
# IMPORTANTE: adicionar localhost no console do reCAPTCHA para dev local funcionar
# IMPORTANTE: adicionar o dominio real no console do reCAPTCHA antes de ir para producao
# IMPORTANTE: apos alterar este arquivo, reiniciar o servidor frontend (npm run dev)
# Funcionamento: o widget aparece sempre que VITE_RECAPTCHA_SITE_KEY estiver definida.
#   Para desativar temporariamente em dev, defina VITE_RECAPTCHA_ENABLED=false.
VITE_RECAPTCHA_SITE_KEY=
# false = desativa o widget (bypass para dev sem chave). Ausente ou qualquer outro valor = ativo.
VITE_RECAPTCHA_ENABLED=false
