DATABASE_URL=
# Em desenvolvimento: development | Em producao: production
# IMPORTANTE: ausencia de NODE_ENV assume "production" por seguranca (rotas dev nao sao registradas)
NODE_ENV=development
PORT=3333
FRONTEND_URL=http://localhost:5173
APP_PUBLIC_URL=http://localhost:5173
SESSION_COOKIE_NAME=site_universe_session
SESSION_TTL_DAYS=7
ACCOUNT_MIGRATION_COOKIE_NAME=site_universe_migration
ACCOUNT_MIGRATION_SESSION_TTL_MINUTES=15
# Verificacao de e-mail e por CODIGO MANUAL enviado via Resend (sem link clicavel).
# console = dev local (imprime o codigo no console; proibido em producao).
# resend = envia e-mail real. Em producao use EMAIL_PROVIDER=resend com RESEND_API_KEY.
EMAIL_PROVIDER=resend
# RESEND_API_KEY so existe no backend; NUNCA expor no frontend (sem VITE_).
# Se ausente com EMAIL_PROVIDER=resend, o envio falha (503) — defina em producao.
RESEND_API_KEY=
# Remetente (nome + e-mail). Desenvolvimento sem dominio verificado no Resend:
# use onboarding@resend.dev e envie somente para o e-mail da propria conta Resend.
# Producao: verifique um dominio proprio no Resend e use, por exemplo,
# EMAIL_FROM="Site Universe <noreply@seudominio.com>"
EMAIL_FROM="Site Universe <onboarding@resend.dev>"
# Token TTL e legado (endpoint GET /verify-email ainda existe para compat, mas o
# fluxo oficial e o codigo manual; nenhum link e enviado no e-mail).
EMAIL_VERIFICATION_TOKEN_TTL_HOURS=24
# Tempo de expiracao do CODIGO de verificacao (minutos).
EMAIL_VERIFICATION_EXPIRES_MINUTES=30
EMAIL_VERIFICATION_CODE_LENGTH=6
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_PER_HOUR=5
EMAIL_REQUIRE_VERIFIED=true
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW=1 minute
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW=1 minute
LOGIN_ACCOUNT_LOCK_MAX_FAILURES=5
LOGIN_ACCOUNT_LOCK_MINUTES=15
REGISTER_RATE_LIMIT_MAX=5
REGISTER_RATE_LIMIT_WINDOW=10 minutes
PASSWORD_RESET_RATE_LIMIT_MAX=5
PASSWORD_RESET_RATE_LIMIT_WINDOW=15 minutes
EMAIL_VERIFICATION_RATE_LIMIT_MAX=5
EMAIL_VERIFICATION_RATE_LIMIT_WINDOW=15 minutes
ACCOUNT_MIGRATION_RATE_LIMIT_MAX=5
ACCOUNT_MIGRATION_RATE_LIMIT_WINDOW=15 minutes
# Desative apos o periodo inicial de migracao estar encerrado
ACCOUNT_MIGRATION_ENABLED=true
# reCAPTCHA v2 ("I'm not a robot")
# Obtenha as chaves em https://www.google.com/recaptcha/admin/create
# O dominio usado em staging/producao DEVE estar cadastrado no painel do reCAPTCHA
# Em desenvolvimento pode ser false (sem validacao)
RECAPTCHA_ENABLED=false
RECAPTCHA_SECRET_KEY=
# Sessao unica: true = novo login revoga sessoes anteriores do mesmo usuario
SINGLE_ACTIVE_SESSION=false
# Conexao com os bancos do jogo Grand Fantasia (gf_ms = mundo, gf_ls = contas/login).
GF_DB_HOST=
GF_DB_PORT=5432
GF_DB_USER=
GF_DB_PASSWORD=
GF_DB_NAME=gf_ms
GF_ACCOUNT_DB_NAME=gf_ls
GF_DB_SSL=false
# Criacao de conta no jogo durante o registro do site:
# true (padrao): cada registro novo cria a conta GF (gf_ms.tb_user + gf_ls.accounts);
#   se o banco GF estiver indisponivel, o registro falha (nao cria site user sem conta de jogo).
# false: apenas para dev/local SEM acesso ao banco GF — cria so o usuario do site e
#   registra REGISTER_CREATED_WITHOUT_GAME_ACCOUNT. NAO usar false em staging/producao.
GAME_ACCOUNT_CREATION_ENABLED=true
# false: registra GameDelivery no Site Universe, mas nao escreve no banco GF.
# true: processa entregas no GF usando gf_ms.tb_user e gf_ls.item_receivable.
GAME_DELIVERY_ENABLED=false
# ==========================================================================
# Pagamento — o Site Universe aceita SOMENTE Pix, via OpenPix/Woovi.
# Mercado Pago e Banco Inter NAO sao usados.
# ==========================================================================
# Provedor de pagamento ativo. Unico valor suportado: openpix.
PAYMENT_PROVIDER=openpix
# OPENPIX_APP_ID e o token de autenticacao da API OpenPix (vai no header Authorization).
# NUNCA versionar o valor real e NUNCA expor no frontend (sem prefixo VITE_).
# Em producao com PAYMENT_PROVIDER=openpix, sua ausencia derruba o startup.
OPENPIX_APP_ID=
# Base da API. Padrao: https://api.openpix.com.br
OPENPIX_BASE_URL=https://api.openpix.com.br
# sandbox (testes) | production. Mantenha separado por ambiente.
OPENPIX_ENV=sandbox
# Opcional: segredo para validar HMAC do webhook (header x-openpix-signature).
# Se ausente, o webhook ainda e seguro: a aprovacao sempre reconsulta a OpenPix
# server-to-server antes de liberar Unicoin/entrega.
OPENPIX_WEBHOOK_SECRET=
