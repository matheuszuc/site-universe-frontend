generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  name               String
  email              String    @unique
  emailNormalized    String    @unique @map("email_normalized")
  passwordHash       String    @map("password_hash")
  role               String    @default("user")
  status             String    @default("pending_verification")
  emailVerifiedAt    DateTime? @map("email_verified_at")
  failedLoginCount   Int       @default(0) @map("failed_login_count")
  lockedUntil        DateTime? @map("locked_until")
  lastLoginAt        DateTime? @map("last_login_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  sessions                Session[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  securityEvents          SecurityEvent[]
  orders                  Order[]
  payments                Payment[]
  walletTransactions      WalletTransaction[]
  rewardDeliveries        RewardDelivery[]
  idempotencyKeys         IdempotencyKey[]
  paymentAuditLogs        PaymentAuditLog[]
  rewardCycles            UserRewardCycle[]
  rewardCycleEvents       UserRewardCycleProgressEvent[]
  rewardTierClaims        UserRewardTierClaim[]
  gameAccounts            GameAccount[]
  accountMigrationAuditLogs AccountMigrationAuditLog[]

  @@index([emailNormalized])
  @@map("users")
}

model Session {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  sessionTokenHash String    @unique @map("session_token_hash")
  csrfTokenHash    String?   @map("csrf_token_hash")
  ipHash           String?   @map("ip_hash")
  userAgentHash    String?   @map("user_agent_hash")
  createdAt        DateTime  @default(now()) @map("created_at")
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at")
  expiresAt        DateTime  @map("expires_at")
  revokedAt        DateTime? @map("revoked_at")
  revokedReason    String?   @map("revoked_reason")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenHash         String    @unique @map("token_hash")
  expiresAt         DateTime  @map("expires_at")
  usedAt            DateTime? @map("used_at")
  requestedIpHash   String?   @map("requested_ip_hash")
  createdAt         DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model SecurityEvent {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  eventType String   @map("event_type")
  ipHash    String?  @map("ip_hash")
  userAgent String?  @map("user_agent")
  metadata  Json?    @db.JsonB
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("security_events")
}

model StorePackage {
  id           String   @id @default(uuid()) @db.Uuid
  code         String   @unique
  name         String
  upAmount     Int      @map("up_amount")
  priceCents   Int      @map("price_cents")
  currency     String   @default("BRL")
  isActive     Boolean  @default(true) @map("is_active")
  displayOrder Int      @default(0) @map("display_order")
  metadata     Json?    @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([isActive, displayOrder])
  @@map("store_packages")
}

model Order {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  orderNumber  String    @unique @map("order_number")
  status       String    @default("pending_payment")
  packageCode  String    @map("package_id")
  packageName  String    @map("package_name")
  amountCents  Int       @map("amount_cents")
  currency     String    @default("BRL")
  rewardType   String    @map("reward_type")
  rewardAmount Int       @map("reward_amount")
  paymentId    String?   @unique @map("payment_id") @db.Uuid
  paidAt       DateTime? @map("paid_at")
  expiresAt    DateTime? @map("expires_at")
  cancelledAt  DateTime? @map("cancelled_at")
  metadata     Json?     @db.JsonB
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user               User                            @relation(fields: [userId], references: [id], onDelete: Restrict)
  payment            Payment?                        @relation("OrderCurrentPayment", fields: [paymentId], references: [id], onDelete: Restrict)
  payments           Payment[]                       @relation("OrderPayments")
  walletTransactions WalletTransaction[]
  rewardDeliveries   RewardDelivery[]
  paymentAuditLogs   PaymentAuditLog[]
  rewardCycleEvents  UserRewardCycleProgressEvent[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("orders")
}

model Payment {
  id                  String    @id @default(uuid()) @db.Uuid
  orderId             String    @map("order_id") @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  status              String    @default("pending")
  provider            String
  providerPaymentId   String?   @map("provider_payment_id")
  providerEventId     String?   @map("provider_event_id")
  amountCents         Int       @map("amount_cents")
  currency            String    @default("BRL")
  approvedAt          DateTime? @map("approved_at")
  failedAt            DateTime? @map("failed_at")
  refundedAt          DateTime? @map("refunded_at")
  failureReason       String?   @map("failure_reason")
  rawProviderStatus   String?   @map("raw_provider_status")
  providerPayloadHash String?   @map("provider_payload_hash")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  order              Order                            @relation("OrderPayments", fields: [orderId], references: [id], onDelete: Restrict)
  user               User                             @relation(fields: [userId], references: [id], onDelete: Restrict)
  currentForOrders   Order[]                          @relation("OrderCurrentPayment")
  walletTransactions WalletTransaction[]
  rewardDeliveries   RewardDelivery[]
  paymentAuditLogs   PaymentAuditLog[]
  rewardCycleEvents  UserRewardCycleProgressEvent[]

  @@index([orderId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@map("payments")
}

model WalletTransaction {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  type             String
  status           String
  amount           Int
  currencyType     String    @map("currency_type")
  orderId          String?   @map("order_id") @db.Uuid
  paymentId        String?   @map("payment_id") @db.Uuid
  rewardDeliveryId String?   @unique @map("reward_delivery_id") @db.Uuid
  sourceType       String?   @map("source_type")
  sourceId         String?   @map("source_id")
  idempotencyKey   String?   @unique @map("idempotency_key")
  description      String?
  createdAt        DateTime  @default(now()) @map("created_at")
  postedAt         DateTime? @map("posted_at")
  reversedAt       DateTime? @map("reversed_at")

  user              User                             @relation(fields: [userId], references: [id], onDelete: Restrict)
  order             Order?                           @relation(fields: [orderId], references: [id], onDelete: Restrict)
  payment           Payment?                         @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  rewardDelivery    RewardDelivery?                  @relation("WalletRewardDelivery", fields: [rewardDeliveryId], references: [id], onDelete: SetNull)
  rewardDeliverySource RewardDelivery?               @relation("RewardDeliveryWalletTransaction")
  paymentAuditLogs  PaymentAuditLog[]
  rewardCycleEvents UserRewardCycleProgressEvent[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt])
  @@index([orderId])
  @@index([paymentId])
  @@map("wallet_transactions")
}

model RewardDelivery {
  id                  String    @id @default(uuid()) @db.Uuid
  userId              String    @map("user_id") @db.Uuid
  orderId             String    @map("order_id") @db.Uuid
  paymentId           String    @unique @map("payment_id") @db.Uuid
  walletTransactionId String    @unique @map("wallet_transaction_id") @db.Uuid
  status              String
  rewardType          String    @map("reward_type")
  rewardAmount        Int       @map("reward_amount")
  gameUserId          String?   @map("game_user_id")
  gameDeliveryId      String?   @map("game_delivery_id")
  idempotencyKey      String    @unique @map("idempotency_key")
  attemptCount        Int       @default(0) @map("attempt_count")
  maxAttempts         Int       @default(10) @map("max_attempts")
  nextRetryAt         DateTime? @map("next_retry_at")
  lockedAt            DateTime? @map("locked_at")
  lockedBy            String?   @map("locked_by")
  deliveredAt         DateTime? @map("delivered_at")
  failedAt            DateTime? @map("failed_at")
  cancelledAt         DateTime? @map("cancelled_at")
  lastError           String?   @map("last_error")
  gameResponseHash    String?   @map("game_response_hash")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user              User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  order             Order                 @relation(fields: [orderId], references: [id], onDelete: Restrict)
  payment           Payment               @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  walletTransaction WalletTransaction     @relation("RewardDeliveryWalletTransaction", fields: [walletTransactionId], references: [id], onDelete: Restrict)
  walletSource      WalletTransaction[]   @relation("WalletRewardDelivery")
  paymentAuditLogs  PaymentAuditLog[]
  tierClaims        UserRewardTierClaim[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, nextRetryAt])
  @@map("reward_deliveries")
}

model IdempotencyKey {
  id             String    @id @default(uuid()) @db.Uuid
  scope          String
  key            String
  userId         String?   @map("user_id") @db.Uuid
  requestMethod  String?   @map("request_method")
  requestPath    String?   @map("request_path")
  requestHash    String?   @map("request_hash")
  status         String
  responseStatus Int?      @map("response_status")
  responseBody   Json?     @map("response_body") @db.JsonB
  lockedUntil    DateTime? @map("locked_until")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([scope, key])
  @@index([userId])
  @@index([status, expiresAt])
  @@map("idempotency_keys")
}

model PaymentAuditLog {
  id                  String   @id @default(uuid()) @db.Uuid
  actorType           String   @map("actor_type")
  actorId             String?  @map("actor_id")
  eventType           String   @map("event_type")
  entityType          String   @map("entity_type")
  entityId            String?  @map("entity_id") @db.Uuid
  userId              String?  @map("user_id") @db.Uuid
  orderId             String?  @map("order_id") @db.Uuid
  paymentId           String?  @map("payment_id") @db.Uuid
  rewardDeliveryId    String?  @map("reward_delivery_id") @db.Uuid
  walletTransactionId String?  @map("wallet_transaction_id") @db.Uuid
  idempotencyKey      String?  @map("idempotency_key")
  requestId           String?  @map("request_id")
  ipAddress           String?  @map("ip_address")
  userAgent           String?  @map("user_agent")
  success             Boolean
  reason              String?
  metadata            Json?    @db.JsonB
  createdAt           DateTime @default(now()) @map("created_at")

  user              User?              @relation(fields: [userId], references: [id], onDelete: Restrict)
  order             Order?             @relation(fields: [orderId], references: [id], onDelete: Restrict)
  payment           Payment?           @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  rewardDelivery    RewardDelivery?    @relation(fields: [rewardDeliveryId], references: [id], onDelete: Restrict)
  walletTransaction WalletTransaction? @relation(fields: [walletTransactionId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([orderId])
  @@index([paymentId])
  @@index([rewardDeliveryId])
  @@index([eventType])
  @@index([createdAt])
  @@map("payment_audit_logs")
}

model RewardTier {
  id              String   @id @default(uuid()) @db.Uuid
  code            String   @unique
  name            String
  requiredUpTotal Int      @map("required_up_total")
  displayOrder    Int      @unique @map("display_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  items  RewardTierItem[]
  claims UserRewardTierClaim[]

  @@index([isActive, displayOrder])
  @@map("reward_tiers")
}

model RewardTierItem {
  id              String   @id @default(uuid()) @db.Uuid
  rewardTierId    String   @map("reward_tier_id") @db.Uuid
  itemName        String   @map("item_name")
  itemDescription String?  @map("item_description")
  gameItemId      String   @map("game_item_id")
  quantity        Int      @default(1)
  displayOrder    Int      @default(0) @map("display_order")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  rewardTier RewardTier @relation(fields: [rewardTierId], references: [id], onDelete: Restrict)

  @@index([rewardTierId])
  @@index([rewardTierId, displayOrder])
  @@map("reward_tier_items")
}

model UserRewardCycle {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  cycleNumber   Int       @map("cycle_number")
  status        String
  accumulatedUp Int       @default(0) @map("accumulated_up")
  startedAt     DateTime  @map("started_at")
  completedAt   DateTime? @map("completed_at")
  resetAt       DateTime? @map("reset_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user           User                            @relation(fields: [userId], references: [id], onDelete: Restrict)
  progressEvents UserRewardCycleProgressEvent[]
  claims         UserRewardTierClaim[]

  @@unique([userId, cycleNumber])
  @@index([userId, status])
  @@index([userId, createdAt(sort: Desc)])
  @@map("user_reward_cycles")
}

model UserRewardCycleProgressEvent {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  userRewardCycleId String   @map("user_reward_cycle_id") @db.Uuid
  walletTransactionId String @unique @map("wallet_transaction_id") @db.Uuid
  paymentId         String?  @map("payment_id") @db.Uuid
  orderId           String?  @map("order_id") @db.Uuid
  amountUp          Int      @map("amount_up")
  sourceType        String   @map("source_type")
  sourceId          String   @map("source_id")
  createdAt         DateTime @default(now()) @map("created_at")

  user              User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  userRewardCycle   UserRewardCycle   @relation(fields: [userRewardCycleId], references: [id], onDelete: Restrict)
  walletTransaction WalletTransaction @relation(fields: [walletTransactionId], references: [id], onDelete: Restrict)
  payment           Payment?          @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  order             Order?            @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([sourceType, sourceId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userRewardCycleId, createdAt])
  @@index([paymentId])
  @@index([orderId])
  @@map("user_reward_cycle_progress_events")
}

model UserRewardTierClaim {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  userRewardCycleId String    @map("user_reward_cycle_id") @db.Uuid
  rewardTierId      String    @map("reward_tier_id") @db.Uuid
  status            String
  claimedAt         DateTime? @map("claimed_at")
  deliveryStatus    String    @default("pending_game_integration") @map("delivery_status")
  rewardDeliveryId  String?   @map("reward_delivery_id") @db.Uuid
  idempotencyKey    String?   @unique @map("idempotency_key")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  user              User             @relation(fields: [userId], references: [id], onDelete: Restrict)
  userRewardCycle   UserRewardCycle  @relation(fields: [userRewardCycleId], references: [id], onDelete: Restrict)
  rewardTier        RewardTier       @relation(fields: [rewardTierId], references: [id], onDelete: Restrict)
  rewardDelivery    RewardDelivery?  @relation(fields: [rewardDeliveryId], references: [id], onDelete: Restrict)

  @@unique([userRewardCycleId, rewardTierId])
  @@index([userId, createdAt(sort: Desc)])
  @@index([userRewardCycleId])
  @@index([rewardTierId])
  @@index([status, createdAt])
  @@index([deliveryStatus, createdAt])
  @@map("user_reward_tier_claims")
}

model GameAccount {
  id                         String    @id @default(uuid()) @db.Uuid
  userId                     String    @map("user_id") @db.Uuid
  gameLogin                  String    @unique @map("game_login")
  gameAccountId              String?   @unique @map("game_account_id")
  status                     String
  linkedAt                   DateTime? @map("linked_at")
  verifiedAt                 DateTime? @map("verified_at")
  migratedAt                 DateTime? @map("migrated_at")
  requiresEmailVerification  Boolean   @default(true) @map("requires_email_verification")
  requiresPasswordUpdate     Boolean   @default(true) @map("requires_password_update")
  createdAt                  DateTime  @default(now()) @map("created_at")
  updatedAt                  DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId])
  @@index([status])
  @@map("game_accounts")
}

model LegacyAccountMigrationSession {
  id             String    @id @default(uuid()) @db.Uuid
  sessionTokenHash String  @unique @map("session_token_hash")
  gameLogin      String    @map("game_login")
  gameAccountId  String?   @map("game_account_id")
  status         String
  expiresAt      DateTime  @map("expires_at")
  attempts       Int       @default(0)
  ipHash         String?   @map("ip_hash")
  userAgentHash  String?   @map("user_agent_hash")
  createdAt      DateTime  @default(now()) @map("created_at")
  completedAt    DateTime? @map("completed_at")

  @@index([sessionTokenHash])
  @@index([gameLogin])
  @@index([status, expiresAt])
  @@map("legacy_account_migration_sessions")
}

model AccountMigrationAuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  eventType     String   @map("event_type")
  success       Boolean
  reason        String?
  gameLogin     String?  @map("game_login")
  userId        String?  @map("user_id") @db.Uuid
  ipHash        String?  @map("ip_hash")
  userAgent     String?  @map("user_agent")
  metadata      Json?    @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([eventType])
  @@index([gameLogin])
  @@index([userId])
  @@index([createdAt])
  @@map("account_migration_audit_logs")
}
